# Force platform to avoid QEMU emulation hang
FROM --platform=linux/amd64 golang:1.22-alpine AS build
WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -ldflags="-s -w" -o /bin/mq ./cmd/mq

FROM --platform=linux/amd64 alpine:3.20
RUN apk --no-cache add ca-certificates
COPY --from=build /bin/mq /mq
ENTRYPOINT ["/mq"]
